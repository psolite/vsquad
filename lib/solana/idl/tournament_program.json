  "types": [
    {
      "name": "Duel",
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "authority", "docs": ["Backend signer allowed to finalize + cancel, same role as `Tournament.authority`."], "type": "pubkey" },
          { "name": "duel_id", "docs": ["Matches the `duel` PDA seed."], "type": "u64" },
          { "name": "stake", "docs": ["Lamports each side puts in — always equal on both sides."], "type": "u64" },
          { "name": "challenger", "type": "pubkey" },
          {
            "name": "opponent",
            "docs": ["`Some(wallet)` = targeted challenge, only that wallet can accept.", "`None` = open, first acceptor wins the slot."],
            "type": { "option": "pubkey" }
          },
          { "name": "start_time", "docs": ["Scoring window begins."], "type": "i64" },
          { "name": "end_time", "docs": ["Scoring window ends — finalize allowed after this."], "type": "i64" },
          { "name": "status", "type": { "defined": { "name": "DuelStatus" } } },
          { "name": "result", "type": { "option": { "defined": { "name": "DuelResult" } } } },
          { "name": "challenger_claimed", "type": "bool" },
          { "name": "opponent_claimed", "type": "bool" },
          { "name": "bump", "type": "u8" }
        ]
      }
    },
    {
      "name": "DuelResult",
      "type": {
        "kind": "enum",
        "variants": [
          { "name": "Winner", "fields": ["pubkey"] },
          { "name": "Draw" }
        ]
      }
    },
    {
      "name": "DuelStatus",
      "type": {
        "kind": "enum",
        "variants": [
          { "name": "Open" },
          { "name": "Active" },
          { "name": "Finalized" },
          { "name": "Cancelled" }
        ]
      }
    },
    {
      "name": "Entry",
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "tournament", "type": "pubkey" },
          { "name": "wallet", "type": "pubkey" },
          { "name": "joined_at", "type": "i64" },
          { "name": "claimed", "type": "bool" },
          { "name": "bump", "type": "u8" }
        ]
      }
    },
    {
      "name": "PayoutShare",
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "rank", "docs": ["1 = first place, 2 = second, ..."], "type": "u8" },
          { "name": "basis_points", "docs": ["e.g. 5000 = 50.00%. All shares in a payout table must sum to 10_000."], "type": "u16" }
        ]
      }
    },
    {
      "name": "Standing",
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "wallet", "type": "pubkey" },
          { "name": "rank", "type": "u8" }
        ]
      }
    },
    {
      "name": "Tournament",
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "authority", "docs": ["Creator / backend signer allowed to finalize + cancel."], "type": "pubkey" },
          { "name": "tournament_id", "docs": ["Matches the `tournament` PDA seed."], "type": "u64" },
          { "name": "entry_fee", "docs": ["Lamports, fixed at creation."], "type": "u64" },
          { "name": "max_participants", "type": "u16" },
          { "name": "participant_count", "type": "u16" },
          { "name": "start_time", "docs": ["Unix seconds — joining closes here."], "type": "i64" },
          { "name": "end_time", "docs": ["Unix seconds — `finalize_tournament` allowed after this."], "type": "i64" },
          { "name": "status", "type": { "defined": { "name": "TournamentStatus" } } },
          {
            "name": "final_pool_lamports",
            "docs": ["Pool size snapshotted at `finalize_tournament`, so later claims split a fixed", "amount instead of the live (draining) vault balance."],
            "type": "u64"
          },
          { "name": "vault_bump", "type": "u8" },
          { "name": "bump", "type": "u8" },
          { "name": "payout_table", "type": { "vec": { "defined": { "name": "PayoutShare" } } } },
          { "name": "final_standings", "type": { "vec": { "defined": { "name": "Standing" } } } }
        ]
      }
    },
    {
      "name": "TournamentStatus",
      "type": {
        "kind": "enum",
        "variants": [
          { "name": "Open" },
          { "name": "Locked" },
          { "name": "Finalized" },
          { "name": "Cancelled" }
        ]
      }
    }
  ],
  "constants": [
    { "name": "DUEL_SEED", "type": "bytes", "value": "[100, 117, 101, 108]" },
    { "name": "ENTRY_SEED", "type": "bytes", "value": "[101, 110, 116, 114, 121]" },
    { "name": "TOURNAMENT_SEED", "type": "bytes", "value": "[116, 111, 117, 114, 110, 97, 109, 101, 110, 116]" }
  ]
}
