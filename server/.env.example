PORT=3001
CLIENT_URL=http://localhost:5173

# ── TxOdds live data ─────────────────────────────────────────────────────────
# Your server Solana wallet secret key as a JSON number array
# Generate one: node -e "const {Keypair}=require('@solana/web3.js');console.log(JSON.stringify(Array.from(Keypair.generate().secretKey)))"
SERVER_WALLET_SECRET_KEY=[]

# 'mainnet' (default) or 'devnet'
TXODDS_NETWORK=mainnet

# 1 = World Cup + Int Friendlies with 60s delay (free, no TxL needed)
# 12 = real-time World Cup + Int Friendlies (free on mainnet, requires on-chain subscription)
TXODDS_SERVICE_LEVEL=1

# Comma-separated league IDs to stream (World Cup league IDs — check TxOdds docs)
TXODDS_LEAGUES=1

# TxL token mint address — from IDL constants (TXLINE_MINT)
TXODDS_TXL_MINT=4Zao8ocPhmMgq7PdsYWyxvqySMGx7xb9cMftPMkEokRG

# Once activated, paste the token here to skip the full auth flow on restart
TXODDS_API_TOKEN=
